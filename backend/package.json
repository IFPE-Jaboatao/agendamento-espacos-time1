{
   "name": "backend",
   "version": "0.0.1",
   "description": "Awesome project developed with TypeORM.",
   "type": "commonjs",
   "dependencies": {
      "bcrypt": "^6.0.0",
      "cors": "^2.8.6",
      "dotenv": "^17.4.0",
      "express": "^5.2.1",
      "express-rate-limit": "^8.3.2",
      "helmet": "^8.1.0",
      "joi": "^18.1.2",
      "jsonwebtoken": "^9.0.3",
      "mysql2": "^3.20.0",
      "reflect-metadata": "^0.2.2",
      "typeorm": "^0.3.28",
      "winston": "^3.19.0"
   },
   "scripts": {
      "dev": "nodemon --exec ts-node src/server.ts",
      "build": "tsc",
      "start": "node dist/server.js"
   },
   "devDependencies": {
      "@types/bcrypt": "^6.0.0",
      "@types/cors": "^2.8.19",
      "@types/express": "^5.0.6",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/node": "^25.5.2",
      "joi-to-swagger": "^6.2.0",
      "nodemon": "^3.1.14",
      "ts-node": "^10.9.2",
      "typescript": "^6.0.2",
      "winston-daily-rotate-file": "^5.0.0"
   },
   "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "moduleResolution": "node",
      "rootDir": "./src",
      "outDir": "./dist",
      "strict": false,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "skipLibCheck": true,
      "types": [
         "node"
      ]
   },
   "include": [
      "src/**/*.ts"
   ],
   "exclude": [
      "node_modules"
   ],
   "ts-node": {
      "transpileOnly": false,
      "files": true,
      "compilerOptions": {
         "emitDecoratorMetadata": true,
         "experimentalDecorators": true
      }
   }
}
